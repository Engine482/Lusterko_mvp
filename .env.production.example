APP_ENV=production

# --- Postgres (lusterko-postgres-prod container) -----------------------------
# Use a strong, randomly generated password. Never commit the real value.
POSTGRES_DB=lusterko_prod
POSTGRES_USER=lusterko
POSTGRES_PASSWORD=

# --- Backend -----------------------------------------------------------------
# Inside docker-compose, the backend reaches postgres at host `postgres`.
DATABASE_URL=postgresql+psycopg://lusterko:CHANGE_ME@postgres:5432/lusterko_prod

# Public origin used in invite and password-reset links.
APP_PUBLIC_BASE_URL=https://lusterko.motornyi.com

# Frontend public origin — backend allows credentialed XHR only from here.
CORS_ALLOWED_ORIGINS=https://lusterko.motornyi.com

# --- Frontend ----------------------------------------------------------------
# Frontend is reverse-proxied under the same origin; relative API base avoids
# CORS and cookie-domain issues.
NEXT_PUBLIC_API_BASE_URL=

# --- Invite email delivery (SMTP) -------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
INVITE_FROM_EMAIL=no-reply@lusterko.motornyi.com

# --- Demo open registration -------------------------------------------------
# Set to `true` for the public demo so testers can self-register at /register
# (they get soldier+commander+medic_psych roles via 24h email confirmation).
# Set to `false` once the closed pilot starts.
DEMO_OPEN_REGISTRATION=true
