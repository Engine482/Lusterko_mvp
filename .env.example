APP_ENV=development

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001
DATABASE_URL=postgresql://lusterko:change_me@localhost:5432/lusterko_dev
TEST_DATABASE_URL=postgresql://lusterko:change_me@localhost:5432/lusterko_test

# Local Postgres container
POSTGRES_DB=lusterko_dev
POSTGRES_USER=lusterko
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001

# Auth placeholders. When GOOGLE_CLIENT_ID is empty (and APP_ENV != production)
# the backend uses a deterministic dev-stub OAuth flow so you can sign in
# without real Google credentials. Replace with real values in .env for prod.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=

# Claude Code MCP placeholders. Export these in your shell or local .env.
GITHUB_MCP_PAT=
LUSTERKO_DATABASE_URL=postgresql://lusterko:change_me@localhost:5432/lusterko_dev

