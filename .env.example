APP_ENV=development

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001
DATABASE_URL=postgresql://lusterko:change_me@localhost:5432/lusterko_dev
TEST_DATABASE_URL=postgresql://lusterko:change_me@localhost:5432/lusterko_test

# Local Postgres container
POSTGRES_DB=lusterko_dev
POSTGRES_USER=lusterko
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001

# Public origin of the app — used to build invite, password-reset and
# demo-registration confirmation URLs in outbound email.
APP_PUBLIC_BASE_URL=http://localhost:3001

# When `true`, exposes /register on the frontend and /api/v1/auth/demo/*
# endpoints on the backend. New self-registered testers receive three
# demo roles (soldier+commander+medic_psych). Invite-only flow continues
# to work in parallel.
DEMO_OPEN_REGISTRATION=false

# Allowed origins for credentialed cross-origin XHR (CSV). Default covers
# local dev. On prod set this to the frontend public origin.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# Claude Code MCP placeholders. Export these in your shell or local .env.
GITHUB_MCP_PAT=
LUSTERKO_DATABASE_URL=postgresql://lusterko:change_me@localhost:5432/lusterko_dev

